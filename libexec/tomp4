#!/usr/bin/env ruby

# realpath resolves the symlink that install.sh creates pointing at this script.
SCRIPT_DIR = File.dirname(File.realpath(__FILE__))
ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../Gemfile', SCRIPT_DIR)

require 'bundler/setup'
require 'streamio-ffmpeg'
require 'slop'

require 'pathname'
require 'shellwords'

$opts = Slop.parse do |o|
  o.banner = 'Usage: tomp4 [options] [file|folder]'

  o.string '-o', '--output', 'Target filename'
  o.integer '-w', '--width', 'Scale the video down to this width'
  o.integer '-h', '--height', 'Scale the video down to this height'
  o.integer '-q', '--quality', 'Sets the quality of the output video (0: very good, 50: very lossy, default: 22)', default: 22
  o.on '-r', '--recursive', 'Dives down into sub-folders'
  o.on '-v', '--verbose', 'Enable verbose mode'
  o.on '-y', '--overwrite', 'Overwrite existing files'
  o.on '-s', '--simulate', 'Don\'t do the work, just print the ffmpeg command'
  o.on '-p', '--passthrough', 'Don\'t convert to hevc, only pass the stream into a mp4 container'
  o.string '-c', '--crop', 'Crop the video with these parameters top:bottom:left:right'
end

if $opts.quality? && !$opts[:quality].between?(0, 51)
  abort "Error: --quality must be between 0 and 51 (got #{$opts[:quality]})"
end

FFMPEG_PATH = `which ffmpeg`.chomp
raise "ffmpeg not found" if FFMPEG_PATH == ""

PASSTHROUGH_ARGS = ["-vcodec", "copy", "-metadata:s:v", "language=eng", "-metadata:s:v", "title=Video Track"].freeze
HEVC_ARGS = (PASSTHROUGH_ARGS + ["-tag:v", "hvc1"]).freeze
AUDIO_ARGS = ["-acodec", "aac", "-ac", "2", "-ab", "160k"].freeze

HANDBRAKE_PATH = `which HandBrakeCLI`.chomp
HANDBRAKE_PRESETS_PATH ||= File.join(SCRIPT_DIR, "UserPresets.json")

HANDBRAKE_VIDEO_ARGS = ["--preset-import-file", HANDBRAKE_PRESETS_PATH, "-Z", "HEVC Default (1080p)"].freeze
HANDBRAKE_AUDIO_ARGS = ["--audio-lang-list=any"].freeze
HANDBRAKE_ENABLED = (HANDBRAKE_PATH != "" && File.exist?(HANDBRAKE_PRESETS_PATH))

puts "\n\nNo HandBrakeCLI found - only --passthrough and HEVC remux will work.\n\n" unless HANDBRAKE_ENABLED

def convert_folder(folder)
    Dir.glob(File.join(folder, '*')).sort.each do |e|
    puts e
    if File.directory?(e) && $opts.recursive?
      convert_folder(e)
    elsif File.file?(e) && e.match?(/\.(?:mkv|avi|mov|wmv|flv|webm|m4v|3gp|ogv|mpg|mpeg|divx)\z/i)
      convert_file(e)
    end
  end
end

def convert_file(filename)
  puts "\n\n  Converting #{filename}\n\n"

  movie = FFMPEG::Movie.new(filename)

  is_hevc = movie.metadata[:streams].detect { |stream| stream[:codec_type] == "video" && stream[:codec_name] == "hevc" }

  if movie.width == 0 && movie.height == 0
    puts "\nCould not parse ffmpeg's output for #{filename} :-(\n\n\n"
    return
  end

  puts "    Input: #{movie.width}x#{movie.height} (#{movie.metadata[:streams].detect { |stream| stream[:codec_type] == "video"}[:codec_name]})"

  target_width = movie.width
  target_height = movie.height

  if $opts.width?
    target_width = $opts[:width]
    if movie.width < $opts[:width]
      target_width = movie.width
    end

    target_height = (movie.height * (target_width.to_f / movie.width.to_f)).to_i
    target_height = target_height + 1 if target_height % 2 == 1
  end

  if $opts.height?
    target_height = $opts[:height]
    if movie.height < $opts[:height]
      target_height = movie.height
    end

    target_width = (movie.width * (target_height.to_f / movie.height.to_f)).to_i
    target_width = target_width +1 if target_width % 2 == 1
  end

  puts "    Output: #{target_width}x#{target_height} (hevc)"

  new_filename = $opts[:output] || Pathname.new(filename).sub_ext('.mp4').to_s

  if new_filename == filename
    raise "Source and target are the same"
  end

  ffmpeg_remux = $opts.passthrough? || (is_hevc && !$opts.width? && !$opts.height? && !$opts.quality?)

  if ffmpeg_remux
    video_args = is_hevc ? HEVC_ARGS : PASSTHROUGH_ARGS
    cmd = [FFMPEG_PATH, "-i", filename, *video_args, *AUDIO_ARGS]
    cmd << "-y" if $opts.overwrite?
    cmd << new_filename
  else
    raise "HandBrakeCLI required for conversion" unless HANDBRAKE_ENABLED

    hb_extra = []
    hb_extra.push("-w", target_width.to_s, "--modulus", "2", "--keep-display-aspect") if $opts.width?
    hb_extra.push("-q", $opts[:quality].to_s) if $opts.quality?
    hb_extra.push("--crop-mode", "custom", "--crop", $opts[:crop]) if $opts.crop?

    cmd = [HANDBRAKE_PATH, *HANDBRAKE_VIDEO_ARGS, *HANDBRAKE_AUDIO_ARGS, "-i", filename, *hb_extra, "-o", new_filename]
  end

  if $opts.simulate?
    puts "\n\n   #{ffmpeg_remux ? 'FFMPEG' : 'HandBrake'} Command: #{Shellwords.join(cmd)}\n\n"
  else
    exit($?.exitstatus || 1) unless system(*cmd)
  end
end

if $opts.arguments.length > 0

  $opts.arguments.each do |argument|
    if File.file?(File.expand_path(argument))
      convert_file(File.expand_path(argument))
    elsif File.directory?(File.expand_path(argument))
      convert_folder(File.expand_path(argument))
    end
  end
else
  puts $opts
end
